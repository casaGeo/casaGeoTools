#!/bin/bash
# SC2317: Command appears to be unreachable.
# SC2329: This function is never invoked.
# shellcheck disable=SC2317,SC2329
set -Ceufo pipefail

#####################
# Global Parameters #
#####################

SPHINX_SOURCEDIR='docs/source/'
SPHINX_BUILDDIR='docs/build/'

##############
# Main Tasks #
##############

run-checks() {
	uv run ruff check
	uv run ruff format --check
	uv run mypy -- casageo tests
}

run-tests() {
	run-smoke-tests
	run-unit-tests
}

run-smoke-tests() {
	uv run tests/smoke_test.py
}

run-unit-tests() {
	uv run python -m unittest discover --start-directory='tests'
}

build() {
	uv build
}

build-docs() {
	sphinx-make html
}

#######################
# Supplementary Tasks #
#######################

sphinx-make() {
	uv run sphinx-build        \
		-M "${1:-help}"        \
		"${SPHINX_SOURCEDIR}"  \
		"${SPHINX_BUILDDIR}"   \
		"${@:2}"
}

generate-fixtures() {
	uv run tests/generate_fixtures.py
}

test-artifact() {
	local artifact=$1
	uv run --isolated --no-project --with="${artifact:?}" tests/smoke_test.py
}

while [[ ${1-} == +([[:word:]])=* ]]; do declare -- "$1"; shift; done
time { set -x; "$@"; }; exit;
